#!/usr/bin/env bash
#
# pre-push: 코드(lib/**) 변경을 push하는데 pubspec.yaml의 version이 안 올랐으면 차단.
#
# 전제: 커밋을 만들 때 변경 규모를 판단해 version: X.Y.Z+B 를 올린다.
#       - fix / perf / refactor → patch (Z+1)
#       - feat                  → minor (Y+1, Z=0)
#       - feat! / BREAKING       → major (X+1, Y=Z=0)
#       - 빌드번호(+N)는 항상 +1
# 역할: 이 훅은 "버전 안 올리고 코드 push" 사고를 막는 가드일 뿐, 직접 bump하지 않는다
#       (pre-push 시점엔 push할 ref가 이미 확정돼 commit을 끼워넣을 수 없음).
# 우회: git push --no-verify
#
set -uo pipefail

zero="0000000000000000000000000000000000000000"
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # 브랜치 삭제 push 무시
  [ "$local_sha" = "$zero" ] && continue
  # 신규 브랜치(원격에 추적본 없음)는 검사 생략
  [ "$remote_sha" = "$zero" ] && continue

  range="${remote_sha}..${local_sha}"

  # 이 push 범위에 lib/ 코드 변경이 있나?
  if git diff --name-only "$range" -- lib | grep -q .; then
    # 같은 범위에서 version 라인이 올랐나?
    if ! git diff "$range" -- pubspec.yaml | grep -qE '^\+version:'; then
      echo "✋ pre-push 차단: lib/ 코드 변경이 있는데 pubspec version이 안 올랐습니다." >&2
      echo "   → 변경 규모 판단 후 version: X.Y.Z+B 올려 커밋하세요" >&2
      echo "     (fix→patch, feat→minor, breaking→major / 빌드번호 +1)." >&2
      echo "   → 의도적 우회: git push --no-verify" >&2
      blocked=1
    fi
  fi
done

exit $blocked
